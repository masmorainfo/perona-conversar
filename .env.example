# Environment — Content Operating System (COS)

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cos:cos_dev@localhost:5432/cos_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LLM Provider ────────────────────────────────────────────────────────────
# O sistema detecta automaticamente qual provider usar:
#   • NVIDIA_API_KEY definido (sem OPENAI_API_KEY) → modo NVIDIA NIM  🟢
#   • OPENAI_API_KEY definido                       → modo OpenAI      🔵
#   • Ambos definidos                               → OpenAI tem prioridade
#
# Obtenha sua chave NVIDIA gratuita em: https://build.nvidia.com/explore/
NVIDIA_API_KEY=
OPENAI_API_KEY=

# Escolha explícita de provider: 'nvidia' ou 'openai' (se omitido, decide baseado nas chaves acima)
LLM_PROVIDER=

# ─── NVIDIA NIM — Roteamento de modelo por tarefa ────────────────────────────
# Cada tarefa usa o modelo mais adequado ao seu perfil (velocidade vs qualidade).
# Todos os modelos abaixo têm acesso GRATUITO via NVIDIA NIM.
# Remova a linha para usar o padrão recomendado.
#
# TAREFA              PADRÃO                                    PERFIL
# ──────────────────────────────────────────────────────────────────────────────
NVIDIA_MODEL_TRANSLATION=meta/llama-3.1-8b-instruct          # rápido / batch
NVIDIA_MODEL_CLASSIFICATION=meta/llama-3.1-8b-instruct       # rápido / simples
NVIDIA_MODEL_OBSERVER=meta/llama-3.3-70b-instruct            # raciocínio médio
NVIDIA_MODEL_EDITORIAL=meta/llama-3.3-70b-instruct           # raciocínio médio
NVIDIA_MODEL_SCRIPT=meta/llama-3.1-405b-instruct             # máxima qualidade criativa
NVIDIA_MODEL_HUMANIZER=nvidia/llama-3.1-nemotron-70b-instruct # tom / voz / instrução
NVIDIA_MODEL_VISION=microsoft/phi-3.5-vision-instruct        # análise de imagem
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v2                        # embeddings (4096 dims)

# Modelo padrão quando nenhuma task é especificada (fallback global)
NVIDIA_DEFAULT_MODEL=meta/llama-3.3-70b-instruct

# ─── Outros providers (não suportados ativamente nesta versão) ───────────────
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# ─── Serviços externos ────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Apps ────────────────────────────────────────────────────────────────────
REGISTRY_PORT=3001
SUPERVISOR_PORT=3002

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# Força o uso do renderizador leve do FFmpeg (evita OOM/SIGKILL em servidores com pouca RAM, ex: Railway)
FORCE_FFMPEG=

# Define o slug do canal ativo usado pelo supervisor (padrão: kairo-futebol)
CHANNEL_SLUG=

# ─── Zernio (TikTok / Social Publishing) ─────────────────────────────────
# Obtenha sua chave em: https://zernio.com/dashboard/api-keys
# Conecte TikTok no dashboard Zernio e copie o Account ID
ZERNIO_API_KEY=
ZERNIO_TIKTOK_ACCOUNT_ID=

# ─── Notificações Telegram ────────────────────────────────────────────────────
# O Supervisor envia notificações ao operador via Telegram.
#
# TELEGRAM_BOT_TOKEN — token do bot criado via @BotFather no Telegram
#   1. Abra o Telegram e converse com @BotFather
#   2. Envie /newbot e siga as instruções
#   3. Copie o token aqui
#
# TELEGRAM_CHAT_ID — ID do seu chat pessoal com o bot
#   1. Envie qualquer mensagem para o seu bot
#   2. Acesse: https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Copie o campo "id" dentro de "chat"
#
# Comandos disponíveis no chat:
#   /approve <content-id>  — aprova um vídeo em PENDING_REVIEW
#   /reject <content-id>   — rejeita um vídeo em PENDING_REVIEW
#
# URL do Mission Control (incluída nas notificações de revisão):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MISSION_CONTROL_URL=http://localhost:3000
